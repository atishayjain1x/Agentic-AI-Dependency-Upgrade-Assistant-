WORKER_HOST=0.0.0.0
WORKER_PORT=8123

DATA_DIR=./data

COMMAND_TIMEOUT_SECONDS=600

MAX_ZIP_BYTES=209715200
MAX_UNZIPPED_BYTES=524288000
MAX_ZIP_ENTRIES=20000

ENABLE_AI_ENRICHMENT=true

AI_PROVIDER=gemini

GOOGLE_API_KEY=your-gemini-api-key
LLM_MODEL=gemini-2.0-flash
EMBEDDING_MODEL=models/gemini-embedding-001
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT_SECONDS=45

QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=dependency_upgrade_docs
RAG_DOCS_DIR=./rag-docs

RAG_TOP_K=4
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=150
RAG_INDEX_STATE_PATH=./data/rag-index-state.json

AI_MAX_DEPENDENCIES=12
AI_MAX_CONTEXT_CHARS=500
AI_MAX_LOG_CHARS=1500
AI_MAX_OUTPUT_TOKENS=384
AI_COMPACT_REPORT=true

MAX_FIX_ITERATIONS=3
